# Copy this file to .env and adjust as needed.
# docker-compose will pick it up automatically.

# Port to expose on the host (default: 8000)
# PORT=8000

# Host path for the database and app state (default: ./data)
# DATA_PATH=/mnt/nas/castcharm/data

# Host path for downloaded audio files (default: ./downloads)
# DOWNLOAD_PATH=/mnt/nas/podcasts
